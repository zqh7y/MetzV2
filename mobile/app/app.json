{
  "expo": {
    "name": "Metz",
    "slug": "metz-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#667eea"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.metz.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.metz.app"
    },
    "extra": {
      "eas": {
        "projectId": "1cdc7ba7-3838-4174-8376-80bebcf16925"
      }
    },
    "owner": "justariel",
    "plugins": [
      "expo-font"
    ]
  }
}
